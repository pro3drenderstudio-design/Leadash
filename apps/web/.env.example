# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Redis (Upstash)
UPSTASH_REDIS_URL=rediss://...

# Email providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# AI (Gemini — for reply classification)
GOOGLE_AI_API_KEY=

# Transactional email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@leadash.com

# Outreach
OUTREACH_ENCRYPTION_KEY=32-char-random-string

# Cron
CRON_SECRET=generate-with-openssl-rand-hex-32

# Domain purchase (Porkbun)
PORKBUN_API_KEY=              # pk1_... from Porkbun → Account → API Access
PORKBUN_SECRET_KEY=           # sk1_... from Porkbun → Account → API Access

# Mail sending — Postal (self-hosted on Hetzner)
POSTAL_AGENT_URL=             # e.g. https://mail.yourdomain.com:3001
POSTAL_AGENT_SECRET=          # shared secret between web app and postal-agent (generate a random string)
POSTAL_SMTP_HOST=             # e.g. mail.yourdomain.com
POSTAL_SERVER_IP=             # Public IPv4 of your Hetzner VPS (used in SPF record)
POSTAL_SERVER_ID=1            # Numeric ID of the Postal server (visible in Postal web UI URL)

# Email verifier (self-hosted on Hetzner, same VPS)
VERIFIER_URL=                 # e.g. https://mail.yourdomain.com:3002
VERIFIER_SECRET=              # shared secret between web app and verifier service

# Mail receiving — AWS SES inbound (keep as-is)
AWS_ACCESS_KEY_ID=            # IAM user with AmazonSESFullAccess policy
AWS_SECRET_ACCESS_KEY=        # IAM secret key
AWS_REGION=us-east-1          # SES region

# DNS management (Cloudflare)
CLOUDFLARE_API_TOKEN=         # API token with Zone:DNS:Edit permission
CLOUDFLARE_ZONE_ID=           # Optional: pre-set zone ID (auto-detected from domain if blank)

# Paystack (NGN payments)
PAYSTACK_SECRET_KEY=          # sk_live_... or sk_test_...
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=  # pk_live_... or pk_test_...
